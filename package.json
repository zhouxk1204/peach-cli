{
  "name": "create-peach",
  "version": "0.0.1",
  "description": "A lightweight CLI tool for quickly scaffolding modern web projects with Vue, React, or Vanilla JavaScript/TypeScript templates",
  "main": "index.js",
  "scripts": {
    "dev": "tsdown --watch",
    "build": "tsdown",
    "release": "pnpm build && npm publish",
    "release:patch": "npm version patch && pnpm release",
    "release:minor": "npm version minor && pnpm release",
    "release:major": "npm version major && pnpm release"
  },
  "type": "module",
  "files": [
    "dist",
    "bin",
    "templates",
    "package.json",
    "LICENSE",
    "README.md"
  ],
  "bin": {
    "peach": "bin/peach-cli.js"
  },
  "keywords": [
    "cli",
    "scaffold",
    "scaffolding",
    "template",
    "boilerplate",
    "generator",
    "vue",
    "react",
    "vite",
    "typescript",
    "javascript",
    "frontend",
    "web",
    "create-app",
    "project-starter",
    "peach"
  ],
  "author": {
    "name": "zhouxk",
    "email": "your-email@example.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/zhouxk/peach-cli.git"
  },
  "bugs": {
    "url": "https://github.com/zhouxk/peach-cli/issues"
  },
  "homepage": "https://github.com/zhouxk/peach-cli#readme",
  "license": "MIT",
  "packageManager": "pnpm@10.27.0",
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/prompts": "^2.4.9",
    "commander": "^14.0.1",
    "consola": "^3.4.2",
    "fs-extra": "^11.3.2",
    "giget": "^2.0.0",
    "ora": "^9.0.0",
    "picocolors": "^1.1.1",
    "prompts": "^2.4.2",
    "tsdown": "^0.15.3",
    "typescript": "^5.9.2"
  },
  "dependencies": {
    "cfonts": "^3.3.1",
    "execa": "^9.6.1",
    "gradient-string": "^3.0.0"
  }
